import { useState, useEffect } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { projects, chapters, characters } from '../api';

const statusLabels: Record<string, string> = {
  outline: '大纲', draft: '草稿', review: '审校中', done: '完成',
};

const agentEmoji: Record<string, string> = {
  planner: '📋', writer: '✍️', editor: '🔍', character: '👤',
};

const agentLabel: Record<string, string> = {
  planner: '策划', writer: '作者', editor: '编辑', character: '角色总监',
};

export default function ProjectDetail() {
  const { id } = useParams<{ id: string }>();
  const navigate = useNavigate();
  const [project, setProject] = useState<any>(null);
  const [chapterList, setChapterList] = useState<any[]>([]);
  const [charList, setCharList] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [generating, setGenerating] = useState(false);
  const [writing, setWriting] = useState<number | null>(null);
  const [error, setError] = useState('');
  const [showCharForm, setShowCharForm] = useState(false);
  const [charForm, setCharForm] = useState({ name: '', role: '', description: '', traits: '' });
  const [expandedChapter, setExpandedChapter] = useState<string | null>(null);
  const [tab, setTab] = useState<'chapters' | 'characters'>('chapters');
  const [deletingAll, setDeletingAll] = useState(false);
  const [editingChapter, setEditingChapter] = useState<string | null>(null);
  const [editTitle, setEditTitle] = useState('');
  const [editOutline, setEditOutline] = useState('');

  useEffect(() => { if (id) loadAll(); }, [id]);

  const loadAll = async () => {
    try {
      const [{ project: p }, { chapters: chs }, { characters: chars }] = await Promise.all([
        projects.get(id!),
        chapters.list(id!),
        characters.list(id!),
      ]);
      setProject(p);
      setChapterList(chs);
      setCharList(chars);
    } catch (err: any) {
      setError(err.message);
    } finally {
      setLoading(false);
    }
  };

  const handleGenerateOutline = async () => {
    setGenerating(true);
    setError('');
    try {
      await chapters.generateOutline(id!);
      const { chapters: chs } = await chapters.list(id!);
      setChapterList(chs);
    } catch (err: any) {
      setError(err.message);
    } finally {
      setGenerating(false);
    }
  };

  const handleWriteChapter = async (chapterNumber: number) => {
    setWriting(chapterNumber);
    setError('');
    try {
      await chapters.write(id!, chapterNumber);
      const { chapters: chs } = await chapters.list(id!);
      setChapterList(chs);
    } catch (err: any) {
      setError(err.message);
    } finally {
      setWriting(null);
    }
  };

  const handleDeleteChapter = async (e: React.MouseEvent, chapterId: string) => {
    e.stopPropagation();
    if (!confirm('确定删除这一章？')) return;
    try {
      await chapters.delete(chapterId);
      loadAll();
      setExpandedChapter(null);
    } catch (err: any) {
      setError(err.message);
    }
  };

  const handleStartEdit = (ch: any) => {
    setEditingChapter(ch.id);
    setEditTitle(ch.title);
    setEditOutline(ch.outline || '');
  };

  const handleSaveEdit = async (chapterId: string) => {
    try {
      await chapters.update(chapterId, { title: editTitle, outline: editOutline });
      setEditingChapter(null);
      loadAll();
    } catch (err: any) {
      setError(err.message);
    }
  };

  const handleDeleteAll = async () => {
    if (!confirm(`确定删除全部 ${chapterList.length} 章大纲？此操作不可撤销！`)) return;
    setDeletingAll(true);
    try {
      await chapters.deleteAll(id!);
      setChapterList([]);
      setExpandedChapter(null);
    } catch (err: any) {
      setError(err.message);
    } finally {
      setDeletingAll(false);
    }
  };
  const handleAddCharacter = async (e: React.FormEvent) => {
    e.preventDefault();
    try {
      await characters.create({
        projectId: id,
        name: charForm.name,
        role: charForm.role,
        description: charForm.description,
        traits: charForm.traits.split(/[,，、]/).filter(Boolean),
      });
      setCharForm({ name: '', role: '', description: '', traits: '' });
      setShowCharForm(false);
      const { characters: chars } = await characters.list(id!);
      setCharList(chars);
    } catch (err: any) {
      setError(err.message);
    }
  };

  if (loading) {
    return (
      <div className="min-h-[100dvh] bg-gray-50 flex items-center justify-center">
        <div className="text-gray-400 text-base sm:text-lg">加载中...</div>
      </div>
    );
  }

  if (!project) {
    return (
      <div className="min-h-[100dvh] bg-gray-50 flex items-center justify-center">
        <div className="text-center px-4">
          <p className="text-sm text-gray-500 mb-4">{error || '项目不存在'}</p>
          <button onClick={() => navigate('/')} className="text-orange-500 hover:underline">返回首页</button>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-[100dvh] bg-gray-50 pb-safe">
      <header className="bg-white shadow-sm sticky top-0 z-10">
        <div className="max-w-6xl mx-auto px-3 sm:px-4 py-3 sm:py-4 flex items-center gap-2 sm:gap-4 min-w-0">
          <button
            onClick={() => navigate('/')}
            className="text-gray-400 hover:text-gray-600 p-1.5 sm:p-1 rounded min-w-[32px] min-h-[32px] shrink-0"
          >
            ← 返回
          </button>
          <div className="min-w-0 flex-1">
            <h1 className="text-base sm:text-xl font-bold text-gray-800 truncate">{project.title}</h1>
            <p className="text-[11px] sm:text-xs text-gray-500 truncate">
              {project.genre} · {project.status} · 目标 {project.target_words?.toLocaleString()} 字
            </p>
          </div>
        </div>
      </header>

      <main className="max-w-6xl mx-auto px-3 sm:px-4 py-4 sm:py-6">
        {error && (
          <div className="bg-red-50 text-red-600 px-4 py-3 rounded-lg mb-3 sm:mb-4 text-sm">{error}</div>
        )}

        {project.synopsis && (
          <div className="bg-white rounded-xl shadow-sm p-4 sm:p-5 mb-4 sm:mb-6">
            <h3 className="font-semibold text-gray-800 mb-1.5 sm:mb-2 text-sm sm:text-base">故事简介</h3>
            <p className="text-sm text-gray-600">{project.synopsis}</p>
          </div>
        )}

        {/* Mobile tab switcher */}
        <div className="flex sm:hidden mb-4 bg-white rounded-lg shadow-sm p-1">
          <button
            onClick={() => setTab('chapters')}
            className={`flex-1 py-2.5 rounded-md text-sm font-medium transition ${
              tab === 'chapters' ? 'bg-orange-100 text-orange-600' : 'text-gray-500'
            }`}
          >
            章节 ({chapterList.length})
          </button>
          <button
            onClick={() => setTab('characters')}
            className={`flex-1 py-2.5 rounded-md text-sm font-medium transition ${
              tab === 'characters' ? 'bg-orange-100 text-orange-600' : 'text-gray-500'
            }`}
          >
            角色 ({charList.length})
          </button>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
          {/* Desktop: Characters sidebar / Mobile: tab panel */}
          <div className={`lg:col-span-1 ${tab === 'characters' ? '' : 'hidden sm:block'}`}>
            <div className="bg-white rounded-xl shadow-sm p-4 sm:p-5">
              <div className="flex items-center justify-between mb-3 sm:mb-4">
                <h3 className="font-semibold text-gray-800 text-sm sm:text-base">人物角色</h3>
                <button
                  onClick={() => setShowCharForm(!showCharForm)}
                  className="text-sm text-orange-500 hover:text-orange-600 py-1 px-2 rounded min-h-[32px]"
                >
                  + 添加
                </button>
              </div>

              {showCharForm && (
                <form onSubmit={handleAddCharacter} className="mb-4 p-3 bg-gray-50 rounded-lg space-y-2">
                  <input
                    type="text" placeholder="角色名" value={charForm.name}
                    onChange={e => setCharForm({ ...charForm, name: e.target.value })}
                    className="w-full px-3 py-2.5 sm:py-2 border rounded text-sm sm:text-base" required
                  />
                  <input
                    type="text" placeholder="定位（主角/反派/配角）" value={charForm.role}
                    onChange={e => setCharForm({ ...charForm, role: e.target.value })}
                    className="w-full px-3 py-2.5 sm:py-2 border rounded text-sm sm:text-base"
                  />
                  <textarea
                    placeholder="角色描述" value={charForm.description}
                    onChange={e => setCharForm({ ...charForm, description: e.target.value })}
                    className="w-full px-3 py-2.5 sm:py-2 border rounded text-sm sm:text-base resize-none" rows={2}
                  />
                  <input
                    type="text" placeholder="性格特征（用逗号分隔）" value={charForm.traits}
                    onChange={e => setCharForm({ ...charForm, traits: e.target.value })}
                    className="w-full px-3 py-2.5 sm:py-2 border rounded text-sm sm:text-base"
                  />
                  <div className="flex gap-2">
                    <button type="submit" className="bg-orange-500 text-white px-4 py-2 rounded text-sm min-h-[36px]">保存</button>
                    <button type="button" onClick={() => setShowCharForm(false)} className="text-gray-500 px-4 py-2 text-sm min-h-[36px]">取消</button>
                  </div>
                </form>
              )}

              {charList.length === 0 ? (
                <p className="text-sm text-gray-400">还没有角色，添加一些吧</p>
              ) : (
                <div className="space-y-2 max-h-[50vh] lg:max-h-[70vh] overflow-y-auto">
                  {charList.map(c => (
                    <div key={c.id} className="p-2.5 sm:p-2 bg-gray-50 rounded-lg">
                      <div className="flex items-center gap-2 flex-wrap">
                        <span className="font-medium text-sm">{c.name}</span>
                        <span className="text-xs text-gray-400">{c.role}</span>
                      </div>
                      <p className="text-xs text-gray-500 mt-1 line-clamp-2">{c.description}</p>
                      {c.traits?.length > 0 && (
                        <div className="flex gap-1 mt-1.5 flex-wrap">
                          {c.traits.map((t: string, i: number) => (
                            <span key={i} className="text-[10px] sm:text-xs bg-orange-50 text-orange-600 px-1.5 py-0.5 rounded">{t}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>

          {/* Chapters */}
          <div className={`lg:col-span-2 ${tab === 'chapters' ? '' : 'hidden sm:block'}`}>
            <div className="bg-white rounded-xl shadow-sm p-4 sm:p-5">
              <div className="flex items-center justify-between mb-3 sm:mb-4 gap-2 flex-wrap">
                <h3 className="font-semibold text-gray-800 text-sm sm:text-base">
                  章节列表 ({chapterList.length})
                </h3>
                <div className="flex gap-2 flex-wrap">
                  {chapterList.length > 0 && (
                    <button
                      onClick={handleDeleteAll}
                      disabled={deletingAll}
                      className="text-[11px] sm:text-xs text-red-500 hover:bg-red-50 px-2 sm:px-3 py-1.5 sm:py-1 rounded border border-red-200 disabled:opacity-50 min-h-[32px] sm:min-h-[28px]"
                    >
                      {deletingAll ? '删除中...' : '🗑 清空大纲'}
                    </button>
                  )}
                  <button
                    onClick={handleGenerateOutline}
                    disabled={generating}
                    className="bg-orange-500 text-white px-3 sm:px-4 py-2 sm:py-1.5 rounded-lg text-xs sm:text-sm font-medium hover:bg-orange-600 transition disabled:opacity-50 min-h-[36px] shrink-0"
                  >
                    {generating ? '🦞 规划中...' : '🤖 AI 生成大纲'}
                  </button>
                </div>
              </div>

              {chapterList.length === 0 ? (
                <div className="text-center py-10 sm:py-12">
                  <div className="text-3xl sm:text-4xl mb-2 sm:mb-3">📖</div>
                  <p className="text-sm text-gray-500 mb-4">还没有章节，先用 AI 生成大纲吧</p>
                  <button
                    onClick={handleGenerateOutline}
                    disabled={generating}
                    className="bg-orange-500 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-orange-600 disabled:opacity-50 min-h-[44px]"
                  >
                    {generating ? '生成中...' : 'AI 生成大纲'}
                  </button>
                </div>
              ) : (
                <div className="space-y-2 max-h-[65vh] lg:max-h-[75vh] overflow-y-auto">
                  {chapterList.map(ch => (
                    <div key={ch.id} className="border rounded-lg overflow-hidden">
                      <div
                        className="flex items-center justify-between p-3 hover:bg-gray-50 cursor-pointer gap-2 min-h-[44px]"
                        onClick={() => setExpandedChapter(expandedChapter === ch.id ? null : ch.id)}
                      >
                        <div className="flex items-center gap-2 sm:gap-3 min-w-0 flex-1 flex-wrap">
                          <span className="text-xs sm:text-sm font-medium text-gray-500 shrink-0">
                            第{ch.number}章
                          </span>
                          <span className="text-xs sm:text-sm text-gray-800 truncate">{ch.title}</span>
                          <span className={`text-[10px] sm:text-xs px-1.5 py-0.5 rounded shrink-0 ${
                            ch.status === 'done' ? 'bg-green-100 text-green-600' :
                            ch.status === 'draft' ? 'bg-blue-100 text-blue-600' :
                            ch.status === 'review' ? 'bg-yellow-100 text-yellow-600' :
                            'bg-gray-100 text-gray-500'
                          }`}>
                            {statusLabels[ch.status] || ch.status}
                          </span>
                          {ch.word_count > 0 && (
                            <span className="text-[10px] sm:text-xs text-gray-400 shrink-0">{ch.word_count}字</span>
                          )}
                        </div>
                        <div className="flex items-center gap-1.5 sm:gap-2 shrink-0">
                          <button
                            onClick={e => { e.stopPropagation(); handleStartEdit(ch); }}
                            className="text-[10px] sm:text-xs text-gray-400 hover:text-blue-500 px-1.5 py-1 rounded min-h-[28px]"
                            title="编辑"
                          >
                            ✏️
                          </button>
                          <button
                            onClick={e => handleDeleteChapter(e, ch.id)}
                            className="text-[10px] sm:text-xs text-gray-400 hover:text-red-500 px-1.5 py-1 rounded min-h-[28px]"
                            title="删除"
                          >
                            🗑
                          </button>
                          {ch.status === 'outline' && (
                            <button
                              onClick={e => { e.stopPropagation(); handleWriteChapter(ch.number); }}
                              disabled={writing === ch.number}
                              className="text-[10px] sm:text-xs bg-blue-500 text-white px-2 sm:px-3 py-1.5 sm:py-1 rounded hover:bg-blue-600 disabled:opacity-50 min-h-[32px] sm:min-h-[28px]"
                            >
                              {writing === ch.number ? '写作中...' : '✍️ 写本章'}
                            </button>
                          )}
                          <span className="text-gray-300 text-[10px] sm:text-xs shrink-0 px-1">
                            {expandedChapter === ch.id ? '▲' : '▼'}
                          </span>
                        </div>
                      </div>

                      {expandedChapter === ch.id &&
                        <div className="border-t p-3 sm:p-4 bg-gray-50">
                          {editingChapter === ch.id &&
                            <div className="space-y-3">
                              <input
                                type="text"
                                value={editTitle}
                                onChange={e => setEditTitle(e.target.value)}
                                className="w-full px-3 py-2 border rounded text-sm font-medium"
                                placeholder="章节标题"
                              />
                              <textarea
                                value={editOutline}
                                onChange={e => setEditOutline(e.target.value)}
                                className="w-full px-3 py-2 border rounded text-sm resize-none"
                                rows={4}
                                placeholder="章节概要"
                              />
                              <div className="flex gap-2">
                                <button
                                  onClick={(e) => { e.stopPropagation(); handleSaveEdit(ch.id); }}
                                  className="bg-blue-500 text-white px-3 py-1.5 rounded text-xs min-h-[32px]"
                                >
                                  保存
                                </button>
                                <button
                                  onClick={(e) => { e.stopPropagation(); setEditingChapter(null); }}
                                  className="text-gray-500 px-3 py-1.5 rounded text-xs min-h-[32px]"
                                >
                                  取消
                                </button>
                              </div>
                            </div>
                          }
                          {editingChapter !== ch.id &&
                            <div>
                              {ch.outline &&
                                <div className="mb-3">
                                  <h4 className="text-[11px] sm:text-xs font-medium text-gray-500 mb-1">大纲</h4>
                                  <p className="text-xs sm:text-sm text-gray-700 whitespace-pre-wrap">{ch.outline}</p>
                                </div>
                              }
                              {ch.content &&
                                <div>
                                  <h4 className="text-[11px] sm:text-xs font-medium text-gray-500 mb-1">正文</h4>
                                  <div className="text-xs sm:text-sm text-gray-800 whitespace-pre-wrap max-h-60 sm:max-h-80 overflow-y-auto bg-white p-3 rounded border leading-relaxed">
                                    {ch.content}
                                  </div>
                                </div>
                              }
                              {ch.agentNotes?.length > 0 &&
                                <div className="mt-3 p-2.5 sm:p-3 bg-orange-50 rounded">
                                  <h4 className="text-[11px] sm:text-xs font-medium text-orange-700 mb-1">AI 写作笔记</h4>
                                  {ch.agentNotes.map((note: any, i: number) =>
                                    <details key={i} className="text-[11px] sm:text-xs text-gray-600 mb-1">
                                      <summary className="cursor-pointer text-orange-600 py-1">
                                        {agentEmoji[note.role] || '🤖'} {agentLabel[note.role] || note.role}
                                        {note.usage ? ` · ${note.usage.inputTokens + note.usage.outputTokens} tokens` : ''}
                                      </summary>
                                      <p className="mt-1 whitespace-pre-wrap text-gray-500 pl-1">{note.content?.slice(0, 500)}</p>
                                    </details>
                                  )}
                                </div>
                              }
                            </div>
                          }
                        </div>
                      }
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </main>
    </div>
  );
}
